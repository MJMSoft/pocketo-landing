---
import { WHATSAPP } from '../consts';
// Floating WhatsApp action. Coral to respect the single-accent theme lock; the
// WhatsApp glyph keeps it instantly recognizable. Points at the WHATSAPP.link
// placeholder for now (update the number in src/consts.ts).
---

<a
  href={WHATSAPP.link}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Escríbenos por WhatsApp"
  class="wa-fab group fixed bottom-5 right-5 z-50 inline-flex items-center gap-2 rounded-2xl bg-coral px-4 py-3 font-semibold text-ink shadow-[0_12px_30px_-8px_rgba(244,164,124,0.55)] sm:bottom-7 sm:right-7"
>
  <svg
    width="22"
    height="22"
    viewBox="0 0 24 24"
    fill="currentColor"
    aria-hidden="true"
    class="shrink-0"
  >
    <path
      d="M19.05 4.91A9.82 9.82 0 0 0 12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.9-4.45 9.9-9.91 0-2.65-1.03-5.14-2.9-7.02ZM12.05 20.15h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.21 8.21 0 0 1-1.26-4.38c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.23-8.23 8.23Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.8-.79.97-.14.16-.29.18-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.39.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.4-.42-.56-.43-.14-.01-.31-.01-.48-.01a.92.92 0 0 0-.66.31c-.23.25-.87.85-.87 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.75.59.25 1.05.4 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.15-1.18-.06-.1-.22-.16-.47-.28Z"
    ></path>
  </svg>
  <span class="hidden text-sm sm:inline">Escríbenos</span>
</a>

<style>
  .wa-fab {
    transition: transform 200ms cubic-bezier(0.23, 1, 0.32, 1),
      background-color 200ms ease;
  }
  @media (hover: hover) and (pointer: fine) {
    .wa-fab:hover {
      transform: translateY(-2px);
      background-color: var(--color-coral-strong);
    }
  }
  .wa-fab:active {
    transform: scale(0.96);
  }
  @media (prefers-reduced-motion: reduce) {
    .wa-fab {
      transition: none;
    }
  }
</style>
