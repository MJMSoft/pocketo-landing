---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { ORDER, PRODUCTS } from '../consts';

// Resolve product photos from src/assets/products by filename stem.
const files = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/products/*.png',
  { eager: true }
);
const imgFor = (stem: string) => files[`../assets/products/${stem}.png`].default;

const [hero, ...rest] = PRODUCTS;
---

<section id="destacados" class="border-t border-line bg-surface-2">
  <div class="mx-auto max-w-7xl px-5 py-20 sm:px-8 sm:py-28">
    <div data-reveal class="max-w-2xl">
      <h2
        class="font-display text-3xl font-semibold leading-tight tracking-tight text-cream sm:text-5xl"
      >
        Lo que más piden
      </h2>
      <p class="mt-4 text-lg text-mist">
        Congelado y porcionado, listo para terminar en tu sartén o tu horno.
        Precios y carta completa en la tienda.
      </p>
    </div>

    <!-- Wide feature: the classic -->
    <a
      href={ORDER.menu}
      data-reveal
      class="lift group mt-12 grid grid-cols-1 overflow-hidden rounded-3xl border border-line bg-surface md:grid-cols-2"
    >
      <div class="relative aspect-[16/11] md:aspect-auto md:h-full md:min-h-[24rem]">
        <Image
          src={imgFor(hero.img)}
          alt={`${hero.name}, empacada y congelada`}
          width={900}
          height={900}
          class="absolute inset-0 h-full w-full object-cover"
          loading="lazy"
        />
      </div>
      <div class="flex flex-col justify-center gap-4 p-8 sm:p-10">
        <h3
          class="font-display text-3xl font-semibold leading-tight tracking-tight text-cream sm:text-4xl"
        >
          {hero.name}
        </h3>
        <p class="text-lg text-mist">{hero.note}.</p>
        <div class="mt-2 flex items-center gap-4">
          <span class="font-display text-2xl font-semibold text-cream"
            >{hero.price}</span
          >
          <span
            class="inline-flex items-center gap-1.5 text-base font-semibold text-coral"
          >
            Pedir
            <svg
              width="16"
              height="16"
              viewBox="0 0 16 16"
              fill="none"
              aria-hidden="true"
              class="transition-transform duration-200 group-hover:translate-x-0.5"
            >
              <path
                d="M3 8h10M9 4l4 4-4 4"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </span>
        </div>
      </div>
    </a>

    <!-- The rest: a six-up grid -->
    <div class="mt-4 grid grid-cols-2 gap-4 lg:grid-cols-3">
      {
        rest.map((product) => (
          <a
            href={ORDER.menu}
            data-reveal
            class="lift group flex flex-col overflow-hidden rounded-3xl border border-line bg-surface"
          >
            <div class="aspect-square">
              <Image
                src={imgFor(product.img)}
                alt={`${product.name}, empacada y congelada`}
                width={560}
                height={560}
                class="h-full w-full object-cover"
                loading="lazy"
              />
            </div>
            <div class="flex flex-1 flex-col gap-2 p-5">
              <h3 class="font-display text-lg font-semibold leading-tight text-cream">
                {product.name}
              </h3>
              <p class="text-sm text-mist">{product.note}</p>
              <div class="mt-auto flex items-center justify-between pt-3">
                <span class="text-base font-semibold text-cream">
                  {product.price}
                </span>
                <span class="inline-flex items-center gap-1 text-sm font-semibold text-coral">
                  Pedir
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 16 16"
                    fill="none"
                    aria-hidden="true"
                    class="transition-transform duration-200 group-hover:translate-x-0.5"
                  >
                    <path
                      d="M3 8h10M9 4l4 4-4 4"
                      stroke="currentColor"
                      stroke-width="1.6"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                </span>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
