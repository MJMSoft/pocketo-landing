---
import { WHATSAPP } from '../consts';

const inputBase =
  'w-full rounded-2xl border border-line bg-ink px-4 py-3 text-cream placeholder:text-mist/70 focus:border-coral focus:outline-none';
---

<section id="cotizar" class="border-t border-line bg-surface-2">
  <div
    class="mx-auto grid max-w-7xl grid-cols-1 gap-12 px-5 py-20 sm:px-8 sm:py-28 lg:grid-cols-12 lg:gap-16"
  >
    <div data-reveal class="lg:col-span-5">
      <h2
        class="font-display text-3xl font-semibold leading-tight tracking-tight text-cream sm:text-5xl"
      >
        Cotiza tu evento o tu pedido al por mayor
      </h2>
      <p class="mt-5 text-lg text-mist">
        Cuéntanos qué necesitas y te escribimos por WhatsApp en menos de 24
        horas. Un solo formulario para eventos y para distribución.
      </p>
      <p class="mt-6 text-base text-mist">
        ¿Prefieres escribir directo? Háblanos al
        <a
          href={WHATSAPP.link}
          class="font-medium text-coral underline-offset-4 hover:underline"
          >{WHATSAPP.display}</a
        >.
      </p>
    </div>

    <div data-reveal class="lg:col-span-7">
      <form
        name="cotizacion"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        action="/gracias"
        class="rounded-3xl border border-line bg-surface p-6 sm:p-8"
      >
        <input type="hidden" name="form-name" value="cotizacion" />
        <p class="hidden">
          <label
            >No llenar si eres humano: <input name="bot-field" /></label
          >
        </p>

        <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
          <div class="flex flex-col gap-2">
            <label for="nombre" class="text-sm font-medium text-cream"
              >Nombre completo <span class="text-coral">*</span></label
            >
            <input
              id="nombre"
              name="nombre"
              type="text"
              required
              autocomplete="name"
              class={inputBase}
            />
          </div>

          <div class="flex flex-col gap-2">
            <label for="whatsapp" class="text-sm font-medium text-cream"
              >WhatsApp <span class="text-coral">*</span></label
            >
            <input
              id="whatsapp"
              name="whatsapp"
              type="tel"
              required
              value="+57 "
              inputmode="tel"
              autocomplete="tel"
              class={inputBase}
            />
          </div>

          <div class="flex flex-col gap-2 sm:col-span-2">
            <label for="email" class="text-sm font-medium text-cream"
              >Email <span class="text-mist">(opcional)</span></label
            >
            <input
              id="email"
              name="email"
              type="email"
              autocomplete="email"
              class={inputBase}
            />
          </div>
        </div>

        <fieldset class="mt-6">
          <legend class="text-sm font-medium text-cream"
            >¿Para qué necesitas cotización? <span class="text-coral">*</span
            ></legend
          >
          <div class="mt-3 grid grid-cols-1 gap-3 sm:grid-cols-2">
            <label
              class="flex cursor-pointer items-center gap-3 rounded-2xl border border-line bg-ink px-4 py-3 text-cream has-[:checked]:border-coral has-[:checked]:bg-coral/10"
            >
              <input
                type="radio"
                name="tipo"
                value="Evento privado"
                required
                checked
                class="h-4 w-4 accent-coral"
              />
              Evento privado
            </label>
            <label
              class="flex cursor-pointer items-center gap-3 rounded-2xl border border-line bg-ink px-4 py-3 text-cream has-[:checked]:border-coral has-[:checked]:bg-coral/10"
            >
              <input
                type="radio"
                name="tipo"
                value="Distribución al por mayor"
                class="h-4 w-4 accent-coral"
              />
              Distribución al por mayor
            </label>
          </div>
        </fieldset>

        <div class="mt-6 flex flex-col gap-2">
          <label for="mensaje" class="text-sm font-medium text-cream"
            >Cuéntanos más <span class="text-coral">*</span></label
          >
          <p id="mensaje-help" class="text-sm text-mist">
            Para eventos: fecha tentativa, número de personas y ubicación. Para
            mayor: tipo de negocio y volumen estimado al mes.
          </p>
          <textarea
            id="mensaje"
            name="mensaje"
            required
            rows="5"
            aria-describedby="mensaje-help"
            class={`${inputBase} resize-y`}></textarea>
        </div>

        <button
          type="submit"
          class="btn-primary mt-7 inline-flex w-full items-center justify-center rounded-2xl bg-coral px-7 py-3.5 text-base font-semibold text-ink sm:w-auto"
        >
          Enviar solicitud
        </button>
      </form>
    </div>
  </div>
</section>

<script>
  // Progressive enhancement: when a "Cotizar" CTA carries a tipo hint, preselect
  // the matching radio so the form opens on the right path. Falls back cleanly
  // (the anchor still scrolls to the form) when JS is off.
  const selectTipo = (tipo: string | null) => {
    if (tipo !== 'evento' && tipo !== 'mayor') return;
    const value =
      tipo === 'mayor' ? 'Distribución al por mayor' : 'Evento privado';
    const radio = document.querySelector<HTMLInputElement>(
      `input[name="tipo"][value="${value}"]`
    );
    if (radio) radio.checked = true;
  };

  document.querySelectorAll<HTMLAnchorElement>('a[data-tipo]').forEach((a) => {
    a.addEventListener('click', () => selectTipo(a.dataset.tipo ?? null));
  });
</script>
