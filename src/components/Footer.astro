---
import { Image } from 'astro:assets';
import { STREET, WHATSAPP, ORDER, SOCIALS } from '../consts';
import logo from '../assets/logo.webp';

const lineLinks = [
  { label: 'Pocketo Home', href: '/#lineas' },
  { label: 'Pocketo Street', href: '/#lineas' },
  { label: 'Pocketo Eventos', href: '/#cotizar' },
  { label: 'Pocketo Al Por Mayor', href: '/#cotizar' },
];

const year = 2026;
---

<footer class="border-t border-line bg-ink">
  <div class="mx-auto max-w-7xl px-5 py-16 sm:px-8">
    <div class="grid grid-cols-1 gap-12 sm:grid-cols-2 lg:grid-cols-12">
      <!-- Brand -->
      <div class="lg:col-span-4">
        <Image
          src={logo}
          alt="Pocketo"
          width={72}
          height={72}
          class="h-16 w-16 rounded-2xl border border-line"
          loading="lazy"
        />
        <p class="mt-4 max-w-xs text-base text-mist">
          Comida caleña congelada, hecha a mano. Pide, congela y termina en
          casa.
        </p>
        <a
          href={ORDER.store}
          class="btn-primary mt-6 inline-flex items-center justify-center rounded-2xl bg-coral px-5 py-2.5 text-sm font-semibold text-ink"
          >Pedir ahora</a
        >
      </div>

      <!-- Lines -->
      <nav class="lg:col-span-3" aria-label="Líneas de negocio">
        <h2 class="text-sm font-semibold text-cream">Nuestras líneas</h2>
        <ul class="mt-4 space-y-3">
          {
            lineLinks.map((l) => (
              <li>
                <a
                  href={l.href}
                  class="text-base text-mist transition-colors hover:text-cream"
                >
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <!-- Street / contacto -->
      <div class="lg:col-span-3">
        <h2 class="text-sm font-semibold text-cream">Pocketo Street</h2>
        <address class="mt-4 space-y-2 text-base not-italic text-mist">
          <p>{STREET.address}</p>
          <p>{STREET.hours}</p>
          <p>
            <a
              href={WHATSAPP.link}
              class="transition-colors hover:text-cream"
              aria-label={`Escribir a Pocketo por WhatsApp al ${WHATSAPP.display}`}
              >WhatsApp {WHATSAPP.display}</a
            >
          </p>
        </address>
      </div>

      <!-- Social -->
      <nav class="lg:col-span-2" aria-label="Redes sociales">
        <h2 class="text-sm font-semibold text-cream">Síguenos</h2>
        <ul class="mt-4 space-y-3">
          {
            SOCIALS.map((s) => (
              <li>
                <a
                  href={s.href}
                  target="_blank"
                  rel="me noopener noreferrer"
                  class="text-base text-mist transition-colors hover:text-cream"
                  aria-label={`${s.label} de Pocketo`}
                >
                  {s.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>

    <div
      class="mt-14 flex flex-col gap-4 border-t border-line pt-6 text-sm text-mist sm:flex-row sm:items-center sm:justify-between"
    >
      <p>© {year} Pocketo. Hecho en Cali.</p>
      <div class="flex gap-5">
        <a href="/privacy" class="transition-colors hover:text-cream">Privacidad</a>
        <a href="/data-deletion" class="transition-colors hover:text-cream"
          >Eliminar datos</a
        >
      </div>
    </div>
  </div>
</footer>
