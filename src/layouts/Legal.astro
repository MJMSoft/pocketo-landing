---
import Base from './Base.astro';

interface Props {
  title: string;
  description: string;
  path: string;
  heading: string;
  updated?: string;
}
const { title, description, path, heading, updated } = Astro.props;
---

<Base title={title} description={description} path={path}>
  <article
    class="mx-auto max-w-[640px] px-5 py-16 sm:py-24 [&_a]:text-coral [&_a]:underline-offset-4 hover:[&_a]:underline [&_h2]:mt-10 [&_h2]:font-display [&_h2]:text-xl [&_h2]:font-semibold [&_h2]:text-cream [&_li]:mt-2 [&_p]:mt-4 [&_p]:leading-relaxed [&_p]:text-mist [&_ul]:mt-3 [&_ul]:list-disc [&_ul]:pl-5 [&_ul]:text-mist"
  >
    <h1
      class="font-display text-3xl font-semibold leading-tight tracking-tight text-cream sm:text-4xl"
    >
      {heading}
    </h1>
    {updated && <p class="mt-3 text-sm text-mist">Última actualización: {updated}</p>}
    <div class="mt-8">
      <slot />
    </div>
  </article>
</Base>
